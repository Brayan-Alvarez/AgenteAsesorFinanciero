# ============================================================
# AgenteAsesorFinanciero — Environment Variables
#
# Copy to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit the real .env — it's in .gitignore.
# In production, set these in Railway / Render's dashboard instead.
# ============================================================

# ── LLM Provider ────────────────────────────────────────────
# "ollama" for local dev, "gemini" for cloud/prod
LLM_PROVIDER=ollama

# Ollama (local dev only)
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# Gemini (cloud/prod) — get key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Sheets ────────────────────────────────────────────
BUDGET_SHEET_ID=your_budget_spreadsheet_id_here
EXPENSES_SHEET_ID=your_expenses_spreadsheet_id_here

# LOCAL DEV: path to the service account JSON key file
# The credentials/ folder is gitignored — safe to put it there
GOOGLE_CREDENTIALS_PATH=credentials/service_account.json

# PRODUCTION (Railway / Render): paste the full contents of the JSON key file.
# Copy everything inside the file and paste it as a single-line string.
# Leave blank in local dev (GOOGLE_CREDENTIALS_PATH is used instead).
GOOGLE_CREDENTIALS_JSON=

# ── App config ───────────────────────────────────────────────
# Comma-separated names exactly as they appear in the Sheets tab headers
PERSON_NAMES=Name1,Name2
CURRENCY=COP

# ── FastAPI / CORS ───────────────────────────────────────────
# In production, set this to your Vercel frontend URL so CORS allows it.
# Example: https://finanzas-yourname.vercel.app
FRONTEND_URL=http://localhost:5173
