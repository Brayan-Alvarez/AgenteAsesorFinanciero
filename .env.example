# ============================================================
# AgenteAsesorFinanciero — Environment Variables Template
#
# Copy this file to .env and fill in your real values.
#   cp .env.example .env
#
# NEVER commit the real .env file — it's in .gitignore.
# ============================================================

# --- LLM Provider ---
# Use "ollama" for local development, "gemini" for cloud/prod.
LLM_PROVIDER=ollama

# --- Ollama config (local dev only) ---
# Make sure Ollama is running: `ollama run llama3.2`
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# --- Gemini config (cloud/prod only) ---
# Get your API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Google Sheets ---
# The ID is the long string in the Sheets URL:
#   https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
BUDGET_SHEET_ID=your_budget_google_sheet_id_here
EXPENSES_SHEET_ID=your_expenses_google_sheet_id_here

# Path to the Google service account JSON key file.
# Download from Google Cloud Console → IAM → Service Accounts.
# The credentials/ folder is gitignored — safe to put it there.
GOOGLE_CREDENTIALS_PATH=credentials/service_account.json

# --- App config ---
# Comma-separated names exactly as they appear in the Sheets tab headers.
# Example: if tabs are named "Enero - Ana" and "Enero - Carlos", use "Ana,Carlos"
PERSON_NAMES=Name1,Name2

# Currency label shown in the UI (always COP — no decimals for pesos)
CURRENCY=COP
